@model List<MapLocation>

@{
    ViewData["Title"] = "Kitty Kabinet Locations";
}

<style>
    #map {
        height: 500px;
        width: 100%;
    }
</style>

<div id="map"></div>
<p class="text-muted mt-3 text-center" style="font-size: 1.1rem;">
    Hover over any pin to see the address, and click to view details.
</p>



@section Scripts {
    <script>
    const locations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
</script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            var map = L.map('map').setView([29.6516, -82.3248], 12);
            
            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19
            }).addTo(map);

            locations.forEach(loc => {

                const marker = L.marker([loc.Latitude, loc.Longitude], {
                    icon: L.divIcon({
                        className: 'kabinet-marker',
                        html: `<div class="kabinet-number">${loc.KabinetNumber}</div>`,
                        iconSize: [30, 30],
                        iconAnchor: [15, 30]
                    })
                }).addTo(map);

                marker.bindTooltip(loc.kabinetlocation, {
                    permanent: false,
                    direction: "top"
                });

                marker.on("click", function () {
                    window.location.href = `/Kabinet/ViewKabinet?id=${encodeURIComponent(loc.KabinetNumber)}`
                });
            });

        });
    </script>
    <style> .kabinet-marker {
  background-color: lightslategray;
  color: antiquewhite;
  font-weight: bold;
  border-radius: 50%;
  text-align: center;
  line-height: 30px;
  font-size: 16px;
  border: 2px solid white;
  box-shadow: 0 0 4px rgba(0,0,0,0.4);
}
  .kabinet-number {
    width: 20px;
    height: 20px;
  }
</style>
}




