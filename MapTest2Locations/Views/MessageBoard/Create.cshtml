@model MessageBoard

@{
    ViewData["Title"] = "Create";
}

<h1 class="mb-4">Create a New Post</h1>

<form asp-action="Create" asp-controller="MessageBoard" method="post" class="card p-4 shadow-sm">

    <div class="mb-3">
        <label asp-for="UserName" class="form-label"></label>
        <input asp-for="UserName" class="form-control"></input>
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Post" class="form-label"></label>
        <textarea asp-for="Post" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Post" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="KabinetNumber" class="form-label"></label>
        <input asp-for="KabinetNumber" class="form-control"></input>
        <span asp-validation-for="KabinetNumber" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Submit Post</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>

</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}