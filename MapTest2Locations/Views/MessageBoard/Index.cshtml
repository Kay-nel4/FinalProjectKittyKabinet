@model IEnumerable<MessageBoard>

@{
    ViewData["Title"] = "Kabinet Kommunity Board";
}

<h1 class="mb-4">Kabinet Kommunity Board</h1>

<div class="mb-3">
    <a class="btn btn-primary" asp-action="Create">New Post</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No posts yet. Be the first to share some Mews!
    </div>
}
else
{
    <div class="list-group">
        @foreach (var post in Model)
        {
            <div class="list-group-item mb-3 shadow-sm">
                <h4>@post.UserName</h4>
                <p>@post.Post</p>

                <div class="text-muted" style="font-size: 0.9rem;">
                    Posted on @post.TimeCreated.ToString("MMMM dd, yyyy h:mm tt")
                </div>

                <div class="mt-2">
                    <form asp-action="Delete" asp-route-id="@post.PostNumber" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Delete this post?');">
                            Delete
                        </button>
                    </form>
                    <a asp-action="Details" asp-route-id="@post.PostNumber" 
                       class="btn btn-sm btn-outline-primary">
                        View
                    </a>
                </div>
            </div>
        }
    </div>
}